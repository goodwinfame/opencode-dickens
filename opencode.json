{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-dickens"],
  "agent": {
    "novelist": {
      "description": "Main orchestrator for Dickens novel writing system",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.4,
      "prompt": "{file:./src/agents/novelist.md}"
    },
    "architect": {
      "description": "Story architect — designs structure, characters, and world",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.7,
      "prompt": "{file:./src/agents/architect.md}"
    },
    "scribe": {
      "description": "Writing craftsman — generates chapter prose",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.8,
      "prompt": "{file:./src/agents/scribe.md}"
    },
    "editor": {
      "description": "Quality reviewer — checks prose, consistency, and pacing",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.3,
      "prompt": "{file:./src/agents/editor.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "chronicler": {
      "description": "Context manager — generates summaries and tracks consistency",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-20250514",
      "temperature": 0.2,
      "prompt": "{file:./src/agents/chronicler.md}"
    }
  }
}
